<% if current_active_session %>
  <% session = current_active_session %>
  <div class="bg-green-600 shadow-md" data-controller="active-session" data-active-session-started-at-value="<%= session.started_at.iso8601 %>">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between py-2">
        <!-- Left: pulsing dot + book title + timer -->
        <div class="flex items-center gap-3 min-w-0">
          <span class="relative flex h-3 w-3 flex-shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-300 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-200"></span>
          </span>
          <span class="text-sm font-medium text-white truncate">
            Reading "<%= session.book.title %>"
          </span>
          <span class="text-sm font-mono text-green-100" data-active-session-target="timer">00:00</span>
        </div>

        <!-- Right: Stop button + hidden completion form -->
        <div class="flex items-center gap-2 flex-shrink-0">
          <button type="button"
                  data-action="active-session#stop"
                  data-active-session-target="stopButton"
                  class="inline-flex items-center rounded-md bg-white/20 px-3 py-1.5 text-sm font-medium text-white hover:bg-white/30 transition-colors">
            <svg class="-ml-0.5 mr-1 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <rect x="6" y="6" width="12" height="12" rx="1"/>
            </svg>
            Stop
          </button>

          <!-- Inline completion form (hidden until Stop is clicked) -->
          <div data-active-session-target="completionForm" class="hidden">
            <%= form_with url: complete_reading_session_path(session), method: :post, class: "flex items-center gap-2" do |form| %>
              <label class="text-sm text-white whitespace-nowrap">End page:</label>
              <%= number_field_tag :end_page,
                  session.book.actual_current_page,
                  min: session.book.first_page,
                  max: session.book.last_page,
                  class: "w-20 rounded-md border-0 py-1 text-sm text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-500",
                  data: { active_session_target: "endPageField" } %>
              <%= form.submit "Save", class: "rounded-md bg-white px-3 py-1.5 text-sm font-medium text-green-700 hover:bg-green-50 cursor-pointer transition-colors" %>
              <button type="button" data-action="active-session#cancelStop" class="rounded-md px-2 py-1.5 text-sm text-white/80 hover:text-white">
                Cancel
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
