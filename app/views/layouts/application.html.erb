<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title>BookStack</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full" data-controller="navigation">
    <div class="min-h-full">
      <!-- Navigation -->
      <nav class="bg-indigo-600 shadow-lg">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <%= link_to root_path, class: "text-white text-xl font-bold flex items-center gap-2" do %>
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                  BookStack
                <% end %>
              </div>
              <% if user_signed_in? %>
                <div class="hidden md:block">
                  <div class="ml-10 flex items-baseline space-x-4">
                    <%= link_to "Dashboard", dashboard_path, class: "rounded-md px-3 py-2 text-sm font-medium #{request.path == dashboard_path ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
                    <%= link_to "Books", books_path, class: "rounded-md px-3 py-2 text-sm font-medium #{controller_name == 'books' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
                    <%= link_to "Reading List", reading_list_path, class: "rounded-md px-3 py-2 text-sm font-medium #{controller_name == 'reading_list' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
                    <%= link_to "Pipeline", pipeline_path, class: "rounded-md px-3 py-2 text-sm font-medium #{controller_name == 'pipeline' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
                    <%= link_to "Sessions", reading_sessions_path, class: "rounded-md px-3 py-2 text-sm font-medium #{controller_name == 'reading_sessions' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="hidden md:block">
              <div class="ml-4 flex items-center md:ml-6">
                <% if user_signed_in? %>
                  <span class="text-indigo-100 text-sm mr-4"><%= current_user.email %></span>
                  <%= link_to "Profile", profile_path, class: "rounded-md px-3 py-2 text-sm font-medium text-indigo-100 hover:bg-indigo-500 hover:text-white" %>
                  <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded-md bg-indigo-500 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-400" %>
                <% else %>
                  <%= link_to "Sign in", new_user_session_path, class: "rounded-md px-3 py-2 text-sm font-medium text-indigo-100 hover:bg-indigo-500 hover:text-white" %>
                  <%= link_to "Sign up", new_user_registration_path, class: "ml-2 rounded-md bg-white px-3 py-2 text-sm font-medium text-indigo-600 hover:bg-indigo-50" %>
                <% end %>
              </div>
            </div>
            <!-- Mobile menu button -->
            <div class="-mr-2 flex md:hidden">
              <button type="button" data-action="click->navigation#toggle" class="relative inline-flex items-center justify-center rounded-md bg-indigo-500 p-2 text-indigo-100 hover:bg-indigo-400 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-indigo-600">
                <span class="sr-only">Open main menu</span>
                <svg class="block h-6 w-6" data-navigation-target="menuIcon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
                <svg class="hidden h-6 w-6" data-navigation-target="closeIcon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile menu -->
        <div class="hidden md:hidden" data-navigation-target="menu">
          <% if user_signed_in? %>
            <div class="space-y-1 px-2 pb-3 pt-2 sm:px-3">
              <%= link_to "Dashboard", dashboard_path, class: "block rounded-md px-3 py-2 text-base font-medium #{request.path == dashboard_path ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
              <%= link_to "Books", books_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'books' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
              <%= link_to "Reading List", reading_list_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'reading_list' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
              <%= link_to "Pipeline", pipeline_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'pipeline' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
              <%= link_to "Sessions", reading_sessions_path, class: "block rounded-md px-3 py-2 text-base font-medium #{controller_name == 'reading_sessions' ? 'bg-indigo-700 text-white' : 'text-indigo-100 hover:bg-indigo-500 hover:text-white'}" %>
            </div>
            <div class="border-t border-indigo-500 pb-3 pt-4">
              <div class="flex items-center px-5">
                <div class="text-base font-medium text-white"><%= current_user.email %></div>
              </div>
              <div class="mt-3 space-y-1 px-2">
                <%= link_to "Profile", profile_path, class: "block rounded-md px-3 py-2 text-base font-medium text-indigo-100 hover:bg-indigo-500 hover:text-white" %>
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left rounded-md px-3 py-2 text-base font-medium text-indigo-100 hover:bg-indigo-500 hover:text-white" %>
              </div>
            </div>
          <% else %>
            <div class="space-y-1 px-2 pb-3 pt-2 sm:px-3">
              <%= link_to "Sign in", new_user_session_path, class: "block rounded-md px-3 py-2 text-base font-medium text-indigo-100 hover:bg-indigo-500 hover:text-white" %>
              <%= link_to "Sign up", new_user_registration_path, class: "block rounded-md px-3 py-2 text-base font-medium text-indigo-100 hover:bg-indigo-500 hover:text-white" %>
            </div>
          <% end %>
        </div>
      </nav>

      <%= render "layouts/active_session_banner" %>

      <!-- Flash messages -->
      <% if notice %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-md bg-green-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-green-800"><%= notice %></p>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if alert %>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
          <div class="rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-red-800"><%= alert %></p>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Main content -->
      <main>
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
          <%= yield %>
        </div>
      </main>
    </div>

    <!-- Mobile bottom navigation (for key actions) -->
    <% if user_signed_in? %>
      <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 md:hidden" data-controller="quick-start">
        <div class="flex items-end justify-around py-2">
          <%= link_to dashboard_path, class: "flex flex-col items-center py-2 px-3 #{request.path == dashboard_path ? 'text-indigo-600' : 'text-gray-500'}" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="text-xs mt-1">Home</span>
          <% end %>
          <%= link_to books_path, class: "flex flex-col items-center py-2 px-3 #{controller_name == 'books' ? 'text-indigo-600' : 'text-gray-500'}" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            <span class="text-xs mt-1">Books</span>
          <% end %>
          <button type="button" data-action="click->quick-start#open" class="flex items-center justify-center w-14 h-14 -mt-5 text-white bg-indigo-600 rounded-full shadow-lg hover:bg-indigo-500 active:bg-indigo-700 transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </button>
          <%= link_to pipeline_path, class: "flex flex-col items-center py-2 px-3 #{controller_name == 'pipeline' ? 'text-indigo-600' : 'text-gray-500'}" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span class="text-xs mt-1">Pipeline</span>
          <% end %>
          <%= link_to reading_sessions_path, class: "flex flex-col items-center py-2 px-3 #{controller_name == 'reading_sessions' ? 'text-indigo-600' : 'text-gray-500'}" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-xs mt-1">History</span>
          <% end %>
        </div>

        <!-- Quick Start Modal -->
        <div data-quick-start-target="modal" data-action="click->quick-start#closeOnBackdrop" class="hidden fixed inset-0 z-50 bg-black/50 flex items-end justify-center">
          <div class="bg-white w-full max-w-lg rounded-t-2xl max-h-[70vh] flex flex-col animate-slide-up">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
              <h2 class="text-lg font-semibold text-gray-900">Start Reading</h2>
              <button type="button" data-action="click->quick-start#close" class="p-2 text-gray-400 hover:text-gray-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>
            <div data-quick-start-target="bookList" class="flex-1 overflow-y-auto p-2">
              <!-- Books loaded dynamically -->
            </div>
          </div>
        </div>
      </div>
      <!-- Spacer for mobile bottom nav -->
      <div class="h-16 md:hidden"></div>
    <% end %>
  </body>
</html>
