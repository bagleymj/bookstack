<div class="space-y-6">
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">Books</h2>
    </div>
    <div class="mt-4 flex md:ml-4 md:mt-0">
      <%= link_to new_book_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Book
      <% end %>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="border-b border-gray-200">
    <nav class="-mb-px flex space-x-8">
      <%= link_to "All", books_path, class: "#{params[:status].blank? ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
      <%= link_to "Reading", books_path(status: :reading), class: "#{params[:status] == 'reading' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
      <%= link_to "Unread", books_path(status: :unread), class: "#{params[:status] == 'unread' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
      <%= link_to "Completed", books_path(status: :completed), class: "#{params[:status] == 'completed' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700'} whitespace-nowrap border-b-2 py-4 px-1 text-sm font-medium" %>
    </nav>
  </div>

  <% if @books.any? %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @books.each do |book| %>
        <div class="rounded-lg bg-white p-6 shadow hover:shadow-md transition-shadow">
          <%= link_to book, class: "block" do %>
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-medium text-gray-900 truncate"><%= book.title %></h3>
                <p class="text-sm text-gray-500"><%= book.author || "Unknown author" %></p>
              </div>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= status_badge_class(book.status) %> ml-2 flex-shrink-0">
                <%= book.status.humanize %>
              </span>
            </div>

            <div class="mt-4">
              <div class="flex items-center justify-between text-sm text-gray-500">
                <span><%= book.total_pages %> pages</span>
                <span>Density: <%= book.density.humanize %></span>
              </div>

              <% if book.reading? || book.completed? %>
                <div class="mt-3">
                  <div class="relative pt-1">
                    <div class="overflow-hidden h-2 text-xs flex rounded bg-gray-200">
                      <div style="width:<%= book.progress_percentage %>%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center <%= book.completed? ? 'bg-green-500' : 'bg-indigo-500' %>"></div>
                    </div>
                  </div>
                  <p class="text-xs text-gray-500 mt-1"><%= book.current_page %> / <%= book.total_pages %> pages (<%= book.progress_percentage %>%)</p>
                </div>
              <% else %>
                <p class="mt-3 text-sm text-gray-500">Est. <%= book.formatted_estimated_time %> to read</p>
              <% end %>
            </div>
          <% end %>

          <% if @book_impacts.key?(book.id) %>
            <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between"
                 data-controller="quick-add" data-quick-add-book-id-value="<%= book.id %>">
              <div class="flex items-center gap-2">
                <% delta = @book_impacts[book.id] %>
                <% if delta != 0 %>
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                    <%= delta > 0 ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700' %>">
                    <%= delta > 0 ? "+#{delta}" : delta %>m/day
                  </span>
                <% else %>
                  <span class="text-xs text-gray-400">No change to daily target</span>
                <% end %>
              </div>
              <button type="button"
                      data-action="click->quick-add#add"
                      data-quick-add-target="button"
                      title="Add to reading list"
                      class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs font-medium text-indigo-600 hover:bg-indigo-50 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Schedule
              </button>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No books</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by adding a book to your library.</p>
      <div class="mt-6">
        <%= link_to new_book_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          Add Book
        <% end %>
      </div>
    </div>
  <% end %>
</div>
