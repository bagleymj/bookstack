<!-- Book Search -->
<% if book.new_record? %>
  <div data-controller="book-search" data-book-search-url-value="<%= api_v1_book_search_index_path %>" data-book-search-amazon-tag-value="<%= amazon_affiliate_tag %>" class="mb-8">
    <div class="relative">
      <label class="block text-sm font-medium text-gray-700 mb-1">Search for a book</label>
      <div class="flex gap-2">
        <select data-book-search-target="mode"
                data-action="change->book-search#changeMode"
                class="rounded-lg border-gray-300 py-3 pl-3 pr-8 text-base shadow-sm focus:border-indigo-500 focus:ring-indigo-500 bg-gray-50 text-gray-700">
          <option value="all">All</option>
          <option value="title">Title</option>
          <option value="author">Author</option>
          <option value="isbn">ISBN</option>
        </select>
        <div class="relative flex-1">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <input type="text"
                 data-book-search-target="input"
                 data-action="input->book-search#search"
                 class="block w-full rounded-lg border-gray-300 pl-10 pr-4 py-3 text-base shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
                 placeholder="Search by title, author, or ISBN...">
        </div>
      </div>

      <!-- Search Results Dropdown -->
      <div data-book-search-target="results"
           class="hidden absolute z-20 mt-1 w-full bg-white rounded-lg shadow-lg border border-gray-200 max-h-96 overflow-y-auto">
      </div>
    </div>

    <!-- Divider -->
    <div class="relative mt-6">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-200"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="bg-white px-4 text-gray-500">or enter details manually</span>
      </div>
    </div>
  </div>
<% end %>

<%= form_with(model: book, class: "space-y-6") do |form| %>
  <% if book.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(book.errors.count, "error") %> prohibited this book from being saved:</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc space-y-1 pl-5">
              <% book.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter book title" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :author, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :author, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter author name" %>
    </div>

    <div>
      <%= form.label :first_page, "First page", class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :first_page, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "1" %>
      <p class="mt-1 text-xs text-gray-500">Where to start reading (skip intros, prefaces, etc.)</p>
    </div>

    <div>
      <%= form.label :last_page, "Last page", class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :last_page, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Total pages" %>
      <p class="mt-1 text-xs text-gray-500">Where to stop (skip indexes, appendices, etc.)</p>
    </div>

    <div>
      <%= form.label :words_per_page, "Words per page (optional)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.number_field :words_per_page, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Default: 250" %>
      <p class="mt-1 text-xs text-gray-500">Leave blank to use your default (250 words/page)</p>
    </div>

    <div>
      <%= form.label :difficulty, class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :difficulty, Book.difficulties.keys.map { |d| [d.humanize, d] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      <p class="mt-1 text-xs text-gray-500">How challenging do you expect this book to be?</p>
    </div>

    <div>
      <%= form.label :isbn, "ISBN (optional)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :isbn, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "ISBN-10 or ISBN-13" %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :cover_image_url, "Cover image URL (optional)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.url_field :cover_image_url, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "https://..." %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", books_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= form.submit class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" %>
  </div>
<% end %>
