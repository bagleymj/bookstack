<div class="space-y-6">
  <!-- Header -->
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
        Welcome back<%= current_user.name.present? ? ", #{current_user.name}" : "" %>!
      </h2>
    </div>
    <div class="mt-4 flex md:ml-4 md:mt-0">
      <%= link_to new_book_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Book
      <% end %>
    </div>
  </div>

  <!-- Discrepancy Alerts -->
  <% if @goals_with_discrepancies.any? %>
    <div class="space-y-3">
      <% @goals_with_discrepancies.each do |goal| %>
        <% discrepancy = goal.yesterday_discrepancy %>
        <% if discrepancy %>
          <div class="rounded-lg border-2 <%= discrepancy[:type] == :behind ? 'border-amber-300 bg-amber-50' : 'border-green-300 bg-green-50' %> p-4 shadow-sm">
            <div class="flex items-start gap-3">
              <!-- Icon -->
              <div class="flex-shrink-0 hidden sm:block">
                <% if discrepancy[:type] == :behind %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-100">
                    <svg class="h-6 w-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                  </div>
                <% else %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100">
                    <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                  </div>
                <% end %>
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-semibold <%= discrepancy[:type] == :behind ? 'text-amber-800' : 'text-green-800' %>">
                  <% if discrepancy[:type] == :behind %>
                    Missed <%= discrepancy[:pages] %> pages yesterday
                  <% else %>
                    Read <%= discrepancy[:pages] %> extra pages yesterday!
                  <% end %>
                </h4>
                <p class="mt-0.5 text-sm <%= discrepancy[:type] == :behind ? 'text-amber-700' : 'text-green-700' %>">
                  <%= goal.book.title %>
                </p>

                <!-- Actions -->
                <div class="mt-3 flex flex-col sm:flex-row gap-2">
                  <%= button_to resolve_discrepancy_reading_goal_path(goal, strategy: :redistribute),
                      method: :post,
                      class: "inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-md #{discrepancy[:type] == :behind ? 'bg-amber-100 text-amber-700 hover:bg-amber-200' : 'bg-green-100 text-green-700 hover:bg-green-200'} transition-colors" do %>
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Spread it out
                  <% end %>

                  <%= button_to resolve_discrepancy_reading_goal_path(goal, strategy: :apply_to_today),
                      method: :post,
                      class: "inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-md #{discrepancy[:type] == :behind ? 'bg-amber-600 text-white hover:bg-amber-700' : 'bg-green-600 text-white hover:bg-green-700'} transition-colors" do %>
                    <% if discrepancy[:type] == :behind %>
                      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                      </svg>
                      Catch up today
                    <% else %>
                      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      Credit to today
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Reading Pace -->
  <% unless @reading_pace_progress %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-6">
      <div class="text-center">
        <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
        <h3 class="mt-2 text-sm font-semibold text-gray-900">Set a reading pace</h3>
        <p class="mt-1 text-sm text-gray-500">Track your reading habits and let your pace drive your daily schedule.</p>
        <div class="mt-4">
          <%= link_to "Set pace", profile_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
        </div>
      </div>
    </div>
  <% end %>
  <% if @reading_pace_progress %>
    <% pace = @reading_pace_progress %>
    <% rate_ratio = pace[:target_rate] > 0 ? (pace[:rate].to_f / pace[:target_rate]) : 0 %>
    <% rate_percentage = [(rate_ratio * 100).round, 200].min %>
    <% diff = pace[:rate] - pace[:target_rate] %>
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium leading-6 text-gray-900">Reading Pace</h3>
          <%= link_to "Edit", profile_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
        </div>
        <div class="flex items-center gap-6">
          <!-- Pace gauge -->
          <div class="flex-shrink-0 relative w-24 h-24">
            <svg class="w-24 h-24 transform -rotate-90" viewBox="0 0 100 100">
              <circle cx="50" cy="50" r="42" fill="none" stroke-width="8" class="stroke-gray-200"/>
              <circle cx="50" cy="50" r="42" fill="none" stroke-width="8"
                      class="<%= rate_ratio >= 0.9 ? 'stroke-green-500' : rate_ratio >= 0.5 ? 'stroke-amber-500' : 'stroke-red-400' %>"
                      stroke-linecap="round"
                      stroke-dasharray="<%= (2 * Math::PI * 42).round(1) %>"
                      stroke-dashoffset="<%= ((1 - [rate_ratio, 1.0].min) * 2 * Math::PI * 42).round(1) %>"/>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center">
                <span class="text-lg font-bold text-gray-900"><%= pace[:rate] %></span>
                <span class="block text-[10px] text-gray-500 -mt-0.5"><%= pace[:unit] %></span>
              </div>
            </div>
          </div>
          <!-- Details -->
          <div class="flex-1 min-w-0">
            <p class="text-2xl font-bold text-gray-900">
              <%= pace[:current] %> <span class="text-base font-normal text-gray-500"><%= pace[:unit].split("/").first %> read</span>
            </p>
            <p class="mt-1 text-sm text-gray-600">
              Target: <%= pace[:target_rate] %> <%= pace[:unit] %>
              <span class="text-gray-400">&middot;</span>
              <%= pace[:period_label] %>
            </p>
            <% if @heijunka[:pace_status] %>
              <p class="mt-1 text-sm font-medium <%= @heijunka[:deficit] > 0.5 ? 'text-amber-600' : 'text-green-600' %>">
                <%= @heijunka[:pace_status].capitalize %>
              </p>
            <% elsif diff.abs >= 0.5 %>
              <p class="mt-1 text-sm font-medium <%= diff >= 0 ? 'text-green-600' : 'text-amber-600' %>">
                <% if diff > 0 %>
                  Ahead of pace
                <% else %>
                  Behind pace
                <% end %>
              </p>
            <% else %>
              <p class="mt-1 text-sm font-medium text-green-600">On pace</p>
            <% end %>
            <% if @heijunka[:derived_budget] > 0 %>
              <p class="mt-1 text-xs text-gray-500">
                <%= @heijunka[:derived_budget] %> min/day &middot;
                <%= @heijunka[:projected_completions] %> of <%= @heijunka[:pace_target] %> projected
              </p>
            <% end %>
          </div>
        </div>
        <% if @heijunka[:queue_warning] %>
          <div class="mt-3 rounded-md bg-amber-50 p-3">
            <p class="text-sm text-amber-800"><%= @heijunka[:queue_warning] %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Stats -->
  <% if @stats %>
    <div data-controller="stat-cards"
         data-stat-cards-defaults-value="<%= stat_card_defaults.to_json %>">

      <!-- Header with Customize button -->
      <div class="mb-4 flex items-center justify-between">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Your Stats</h3>
        <button data-action="stat-cards#togglePanel"
                class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1.5 text-sm text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors"
                type="button">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Customize
        </button>
      </div>

      <!-- Settings Panel (hidden by default) -->
      <div data-stat-cards-target="panel" class="hidden mb-4 rounded-lg bg-gray-50 border border-gray-200 p-4">
        <div class="flex items-center justify-between mb-3">
          <h4 class="text-sm font-medium text-gray-700">Show/Hide Stats</h4>
          <button data-action="stat-cards#resetDefaults"
                  class="text-xs text-indigo-600 hover:text-indigo-500"
                  type="button">
            Reset to defaults
          </button>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          <% stat_card_definitions.each do |card| %>
            <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
              <input type="checkbox"
                     data-stat-cards-target="toggle"
                     data-stat-key="<%= card[:key] %>"
                     data-action="stat-cards#toggleStat"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <%= card[:label] %>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Stat Cards Grid -->
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
        <%= render_stat_card(key: "reading_speed", label: "Reading Speed", value: "#{@stats.average_wpm.round} WPM") %>
        <%= render_stat_card(key: "total_sessions", label: "Total Sessions", value: @stats.total_sessions) %>
        <%= render_stat_card(key: "pages_read", label: "Pages Read", value: number_with_delimiter(@stats.total_pages_read)) %>
        <%= render_stat_card(key: "time_reading", label: "Time Reading", value: @stats.total_reading_time_formatted) %>
        <%= render_stat_card(key: "yearly_scheduled", label: "#{Date.current.year} Books Scheduled", value: @yearly_books_scheduled) %>
        <%= render_stat_card(key: "yearly_completed", label: "#{Date.current.year} Books Completed", value: @yearly_books_completed) %>
        <%= render_stat_card(key: "pages_today", label: "Pages Today", value: number_with_delimiter(@pages_today)) %>
        <%= render_stat_card(key: "time_today", label: "Time Today", value: format_duration(@time_today_seconds)) %>
        <%= render_stat_card(key: "pages_this_week", label: "Pages This Week", value: number_with_delimiter(@pages_this_week)) %>
        <%= render_stat_card(key: "time_this_week", label: "Time This Week", value: format_duration(@time_this_week_seconds)) %>
        <%= render_stat_card(key: "pages_per_hour", label: "Pages/Hour", value: @pages_per_hour) %>
        <%= render_stat_card(key: "books_completed", label: "Books Completed", value: @books_completed_all_time) %>
        <%= render_stat_card(key: "avg_pages_session", label: "Avg Pages/Session", value: @avg_pages_per_session) %>
        <%= render_stat_card(key: "avg_session_duration", label: "Avg Session", value: format_duration(@avg_session_duration_seconds)) %>
        <%= render_stat_card(key: "reading_streak", label: "Reading Streak", value: "#{@reading_streak} day#{'s' unless @reading_streak == 1}") %>
      </div>
    </div>
  <% end %>

  <!-- Today's Reading Time -->
  <% if @today_quotas.any? %>
    <div class="rounded-lg bg-gradient-to-r <%= @today_reading_minutes.zero? ? 'from-green-500 to-emerald-600' : 'from-indigo-500 to-purple-600' %> p-6 shadow-lg">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-white/80">Today's Reading</p>
          <% if @today_reading_minutes.zero? %>
            <p class="mt-1 text-3xl font-bold text-white">All done!</p>
            <p class="mt-1 text-sm text-white/80">You've completed all your reading goals for today</p>
          <% else %>
            <p class="mt-1 text-3xl font-bold text-white">
              <% if @today_reading_minutes >= 60 %>
                <%= (@today_reading_minutes / 60.0).round(1) %> hr
              <% else %>
                <%= @today_reading_minutes %> min
              <% end %>
              remaining
            </p>
            <p class="mt-1 text-sm text-white/80">
              across <%= @today_quotas.reject(&:effectively_complete?).count %> book<%= @today_quotas.reject(&:effectively_complete?).count == 1 ? '' : 's' %>
            </p>
          <% end %>
        </div>
        <div class="hidden sm:block">
          <% if @today_reading_minutes.zero? %>
            <svg class="h-16 w-16 text-white/30" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
            </svg>
          <% else %>
            <svg class="h-16 w-16 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Currently Reading (with integrated daily goals) -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium leading-6 text-gray-900">Currently Reading</h3>
          <%= link_to "View all", books_path(status: :reading), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
        </div>
        <% if @books_in_progress.any? %>
          <div class="mt-4 space-y-4">
            <%
              # Build a lookup of today's quotas by book_id
              quotas_by_book = @today_quotas.index_by { |q| q.reading_goal.book_id }
            %>
            <% @books_in_progress.limit(3).each do |book| %>
              <% quota = quotas_by_book[book.id] %>
              <div class="rounded-lg border <%= quota ? 'border-indigo-200 bg-indigo-50/30' : 'border-gray-200' %> p-4 hover:border-indigo-300 transition-colors">
                <div class="flex items-start justify-between">
                  <div class="flex-1 min-w-0">
                    <%= link_to book, class: "hover:text-indigo-600" do %>
                      <p class="font-medium text-gray-900 truncate"><%= book.title %></p>
                    <% end %>
                    <p class="text-sm text-gray-500"><%= book.author %></p>
                  </div>
                  <%= button_to start_book_reading_sessions_path(book), method: :post, class: "ml-2 inline-flex items-center justify-center w-9 h-9 rounded-full bg-indigo-100 text-indigo-600 hover:bg-indigo-200 transition-colors" do %>
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  <% end %>
                </div>

                <% if quota %>
                  <!-- Today's Goal -->
                  <div class="mt-3 flex items-center justify-between p-2 rounded-md <%= quota.effectively_complete? ? 'bg-green-100' : 'bg-white' %>">
                    <div class="flex items-center gap-2">
                      <% if quota.effectively_complete? %>
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span class="text-sm font-medium text-green-700">Today's goal complete!</span>
                      <% else %>
                        <span class="text-sm text-gray-600">
                          <span class="font-medium">Today:</span>
                          read to p. <%= quota.target_page_number %>
                        </span>
                      <% end %>
                    </div>
                    <% unless quota.effectively_complete? %>
                      <span class="text-xs font-medium <%= quota.percentage_complete > 0 ? 'text-indigo-600' : 'text-gray-400' %>">
                        <%= quota.actual_pages %>/<%= quota.target_pages %> pages
                      </span>
                    <% end %>
                  </div>
                <% end %>

                <div class="mt-3 flex items-center gap-4 text-sm">
                  <div class="flex items-center gap-1.5 text-gray-600">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span>p. <%= book.actual_current_page %></span>
                  </div>
                  <div class="flex items-center gap-1.5 text-gray-600">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <span><%= book.remaining_pages %> left</span>
                  </div>
                  <div class="flex items-center gap-1.5 text-gray-600">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span><%= book.formatted_estimated_time %></span>
                  </div>
                </div>

                <div class="mt-3">
                  <% if quota && !quota.effectively_complete? %>
                    <%
                      # Calculate progress segments
                      today_pages = quota.actual_pages
                      pages_read = book.current_page - book.first_page
                      before_today_pages = pages_read - today_pages
                      before_today_pct = (before_today_pages.to_f / book.total_pages * 100).clamp(0, 100)
                      today_pct = (today_pages.to_f / book.total_pages * 100).clamp(0, 100)
                      target_percentage = ((quota.target_page_number - book.first_page).to_f / book.total_pages * 100).clamp(0, 100)
                    %>
                    <!-- Progress bar: before today (indigo) + today's reading (cyan) + target marker -->
                    <div class="relative">
                      <div class="overflow-hidden h-1.5 rounded-full bg-gray-200 flex">
                        <% if before_today_pct > 0 %>
                          <div style="width:<%= before_today_pct %>%" class="h-full bg-indigo-500"></div>
                        <% end %>
                        <% if today_pct > 0 %>
                          <div style="width:<%= today_pct %>%" class="h-full bg-cyan-400"></div>
                        <% end %>
                      </div>
                      <div class="absolute top-0 h-1.5 w-0.5 bg-indigo-800 rounded" style="left: <%= target_percentage %>%"></div>
                    </div>
                  <% else %>
                    <div class="overflow-hidden h-1.5 rounded-full bg-gray-200">
                      <div style="width:<%= book.progress_percentage %>%" class="h-full rounded-full <%= quota&.effectively_complete? ? 'bg-green-500' : 'bg-indigo-500' %>"></div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-4 text-sm text-gray-500">No books in progress. <%= link_to "Add a book", new_book_path, class: "text-indigo-600 hover:text-indigo-500" %> to get started!</p>
        <% end %>
      </div>
    </div>

    <!-- Recent Sessions -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-medium leading-6 text-gray-900">Recent Sessions</h3>
          <%= link_to "View all", reading_sessions_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
        </div>
        <% if @recent_sessions.any? %>
          <div class="mt-4 space-y-3">
            <% @recent_sessions.each do |session| %>
              <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= session.book.title %></p>
                  <p class="text-xs text-gray-500"><%= time_ago_in_words(session.started_at) %> ago</p>
                </div>
                <div class="text-right">
                  <p class="text-sm text-gray-900"><%= session.pages_read %> pages</p>
                  <p class="text-xs text-gray-500"><%= session.words_per_minute&.round %> WPM</p>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-4 text-sm text-gray-500">No reading sessions yet. Start your first session!</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Pipeline Summary -->
  <div class="rounded-lg bg-white shadow">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Reading Pipeline</h3>
        <%= link_to "Full pipeline", pipeline_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
      </div>
      <div data-controller="pipeline-chart"
           data-pipeline-chart-url-value="<%= api_v1_pipeline_index_path %>"
           data-pipeline-chart-compact-value="true"
           class="overflow-x-auto relative"
           style="touch-action: none;">
        <div class="min-h-[100px] flex items-center justify-center text-gray-500">
          Loading pipeline...
        </div>
      </div>
    </div>
  </div>

  <!-- Up Next (Unread Books) -->
  <% if @unread_books.any? %>
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-medium leading-6 text-gray-900">Up Next</h3>
          <%= link_to "View all", books_path(status: :unread), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
        </div>
        <div class="flex gap-4 overflow-x-auto pb-2 -mx-1 px-1">
          <% @unread_books.each do |book| %>
            <%= link_to book, class: "flex-none w-40 rounded-lg border border-gray-200 p-3 hover:border-indigo-300 hover:shadow-sm transition-all" do %>
              <div class="aspect-[3/4] rounded bg-gradient-to-br from-indigo-100 to-indigo-50 flex items-center justify-center mb-2">
                <svg class="w-8 h-8 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              </div>
              <p class="font-medium text-gray-900 text-sm truncate"><%= book.title %></p>
              <p class="text-xs text-gray-500 truncate"><%= book.author %></p>
              <p class="text-xs text-gray-400 mt-1"><%= book.total_pages %> pages</p>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
