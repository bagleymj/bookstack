<%= form_with(model: pipeline, class: "space-y-6") do |form| %>
  <% if pipeline.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="ml-3">
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(pipeline.errors.count, "error") %>:</h3>
        <ul class="mt-2 text-sm text-red-700 list-disc pl-5">
          <% pipeline.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "e.g., 2024 Reading List" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Optional description..." %>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", pipelines_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= form.submit class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  </div>
<% end %>
