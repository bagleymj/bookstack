<div class="mx-auto max-w-2xl">
  <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">Edit Pipeline</h2>

  <div class="mt-8">
    <%= render "form", pipeline: @pipeline %>
  </div>

  <div class="mt-8 pt-8 border-t border-gray-200">
    <h3 class="text-lg font-medium text-red-600">Danger Zone</h3>
    <p class="mt-1 text-sm text-gray-500">Deleting this pipeline will remove all book assignments but not the books themselves.</p>
    <div class="mt-4">
      <%= button_to "Delete Pipeline", pipeline_path(@pipeline), method: :delete, data: { confirm: "Are you sure? This cannot be undone." }, class: "inline-flex items-center rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500" %>
    </div>
  </div>
</div>
