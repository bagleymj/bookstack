<div class="space-y-6">
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">Import / Export</h2>
      <p class="mt-1 text-sm text-gray-500">Import books from Goodreads or export your library for use in other apps.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Import Card -->
    <div class="rounded-lg bg-white p-6 shadow">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-100">
          <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Import from Goodreads</h3>
      </div>

      <div class="space-y-4">
        <div class="rounded-md bg-blue-50 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3 text-sm text-blue-700">
              <p class="font-medium">How to export from Goodreads:</p>
              <ol class="mt-1 list-decimal list-inside space-y-1">
                <li>Go to <strong>My Books</strong> on Goodreads</li>
                <li>Click <strong>Import and export</strong> (left sidebar)</li>
                <li>Click <strong>Export Library</strong></li>
                <li>Upload the downloaded CSV here</li>
              </ol>
            </div>
          </div>
        </div>

        <%= form_tag preview_goodreads_path, method: :post, multipart: true, class: "space-y-4" do %>
          <div>
            <label for="file" class="block text-sm font-medium text-gray-700">Goodreads CSV file</label>
            <div class="mt-1">
              <%= file_field_tag :file, accept: ".csv", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
            </div>
          </div>

          <%= submit_tag "Upload & Preview", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <!-- Export Card -->
    <div class="rounded-lg bg-white p-6 shadow">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100">
          <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900">Export for Goodreads</h3>
      </div>

      <p class="text-sm text-gray-600 mb-4">
        Download your BookStack library as a CSV file compatible with Goodreads import.
        Books will be mapped to the appropriate Goodreads shelves (to-read, currently-reading, read).
      </p>

      <div class="space-y-3">
        <%= link_to export_goodreads_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Export All Books
        <% end %>

        <div class="flex flex-wrap gap-2">
          <%= link_to "Unread only", export_goodreads_path(status: :unread), class: "inline-flex items-center rounded-md bg-white px-3 py-1.5 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
          <%= link_to "Reading only", export_goodreads_path(status: :reading), class: "inline-flex items-center rounded-md bg-white px-3 py-1.5 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
          <%= link_to "Completed only", export_goodreads_path(status: :completed), class: "inline-flex items-center rounded-md bg-white px-3 py-1.5 text-xs font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
        </div>
      </div>
    </div>
  </div>
</div>
