<%= form_with(model: reading_goal, class: "space-y-6") do |form| %>
  <% if reading_goal.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(reading_goal.errors.count, "error") %>:</h3>
          <ul class="mt-2 text-sm text-red-700 list-disc pl-5">
            <% reading_goal.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :book_id, "Book", class: "block text-sm font-medium text-gray-700" %>
    <% if params[:book_id] %>
      <% book = current_user.books.find(params[:book_id]) %>
      <%= form.hidden_field :book_id, value: book.id %>
      <p class="mt-1 text-lg font-medium text-gray-900"><%= book.title %></p>
      <p class="text-sm text-gray-500"><%= book.remaining_pages %> pages remaining</p>
    <% else %>
      <%= form.collection_select :book_id, @books, :id, :title, { prompt: "Select a book" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div>
      <%= form.label :started_on, "Start Date", class: "block text-sm font-medium text-gray-700" %>
      <%= form.date_field :started_on, value: reading_goal.started_on || Date.current, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :target_completion_date, "Target Completion Date", class: "block text-sm font-medium text-gray-700" %>
      <%= form.date_field :target_completion_date, min: Date.current + 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
  </div>

  <div class="rounded-md bg-blue-50 p-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-blue-700">
          Daily quotas will be automatically calculated and adjusted if you miss a day.
        </p>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", pipeline_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= form.submit class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  </div>
<% end %>
