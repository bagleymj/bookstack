<div class="mx-auto max-w-2xl">
  <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
    Reading Session
  </h2>
  <p class="mt-2 text-sm text-gray-600">"<%= @book.title %>" by <%= @book.author %></p>

  <div class="mt-8 rounded-lg bg-white shadow" data-controller="timer" data-timer-book-id-value="<%= @book.id %>">
    <div class="px-4 py-5 sm:p-6">
      <!-- Timer Display -->
      <div class="text-center">
        <div class="text-6xl font-mono font-bold text-indigo-600" data-timer-target="display">
          00:00
        </div>
        <p class="mt-2 text-sm text-gray-500" data-timer-target="statusText">Press Start to begin reading</p>
      </div>

      <!-- Timer Control - Single Toggle Button -->
      <div class="mt-8 flex justify-center">
        <button type="button" data-action="click->timer#toggle" data-timer-target="toggleButton" class="inline-flex items-center rounded-md bg-green-600 px-6 py-3 text-lg font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600 transition-colors duration-200">
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" data-timer-target="toggleIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span data-timer-target="toggleText">Start</span>
        </button>
      </div>

      <!-- Current Progress Info -->
      <div class="mt-8 grid grid-cols-2 gap-4 text-center" data-timer-target="progressInfo">
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-sm text-gray-500">Starting Page</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @book.actual_current_page %></p>
        </div>
        <div class="rounded-lg bg-gray-50 p-4">
          <p class="text-sm text-gray-500">Book Progress</p>
          <p class="text-2xl font-semibold text-gray-900"><%= @book.progress_percentage %>%</p>
        </div>
      </div>

      <!-- Session Completion Form (hidden until timer finishes) -->
      <div data-timer-target="completionForm" class="hidden mt-8">
        <%= form_with url: book_reading_sessions_path(@book), method: :post, scope: :reading_session, data: { timer_target: "form" } do |form| %>
          <%= form.hidden_field :duration_seconds, value: 0, data: { timer_target: "durationField" } %>
          <%= form.hidden_field :start_page, value: @book.current_page %>

          <div class="rounded-md bg-green-50 p-4 mb-6">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-green-800">
                  Great session! You read for <span data-timer-target="finalTime" class="font-bold">0:00</span>
                </p>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <div>
              <label for="end_page" class="block text-sm font-medium text-gray-700">What page are you on now?</label>
              <div class="mt-1 flex items-center gap-3">
                <%= form.number_field :end_page,
                    min: @book.first_page,
                    max: @book.last_page,
                    value: @book.actual_current_page,
                    class: "block w-32 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-lg",
                    data: { timer_target: "endPageField" } %>
                <span class="text-sm text-gray-500">
                  (pages <%= @book.first_page %> - <%= @book.last_page %>)
                </span>
              </div>
            </div>

            <div class="flex items-center gap-2">
              <%= form.check_box :untracked, class: "h-4 w-4 rounded border-gray-300 text-gray-600 focus:ring-gray-500" %>
              <%= form.label :untracked, "Untracked session", class: "text-sm text-gray-600" %>
              <span class="text-xs text-gray-400">(updates progress but won't affect reading speed stats)</span>
            </div>

            <div class="flex justify-end gap-3 pt-4">
              <%= link_to "Discard", @book, class: "rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50", data: { action: "click->timer#discard" } %>
              <%= form.submit "Save Session", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Cancel link (shown before timer finishes) -->
      <div class="mt-8 text-center" data-timer-target="cancelLink">
        <%= link_to "Cancel", @book, class: "text-sm text-gray-500 hover:text-gray-700" %>
      </div>
    </div>
  </div>
</div>
