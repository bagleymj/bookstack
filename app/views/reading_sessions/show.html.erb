<div class="mx-auto max-w-2xl">
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
        Reading Session
      </h2>
      <p class="mt-1 text-lg text-gray-500"><%= @reading_session.book.title %></p>
    </div>
    <div class="mt-4 flex gap-2 md:ml-4 md:mt-0">
      <%= link_to "Back to Book", @reading_session.book, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= link_to "All Sessions", reading_sessions_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to reading_session_path(@reading_session), method: :delete, data: { turbo_confirm: "<%= @reading_session.in_progress? ? 'Discard this reading session?' : 'Delete this reading session?' %>" }, class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500" do %>
        <%= @reading_session.in_progress? ? "Discard" : "Delete" %>
      <% end %>
    </div>
  </div>

  <% if @reading_session.in_progress? %>
    <!-- In-Progress Session -->
    <div class="mt-8 rounded-lg bg-white shadow" data-controller="active-session" data-active-session-started-at-value="<%= @reading_session.started_at.iso8601 %>">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">
            <span class="relative flex h-2 w-2 mr-1.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
            </span>
            In Progress
          </span>
          <span class="text-sm text-gray-500">Started <%= @reading_session.started_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>

        <!-- Timer -->
        <div class="text-center mb-8">
          <div class="text-6xl font-mono font-bold text-green-600" data-active-session-target="timer">00:00</div>
          <p class="mt-2 text-sm text-gray-500">Reading in progress</p>
        </div>

        <dl class="grid grid-cols-2 gap-6">
          <div class="rounded-lg bg-gray-50 p-4 text-center">
            <dt class="text-sm text-gray-600">Start Page</dt>
            <dd class="mt-1 text-2xl font-bold text-gray-900"><%= @reading_session.actual_start_page %></dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4 text-center">
            <dt class="text-sm text-gray-600">Book Progress</dt>
            <dd class="mt-1 text-2xl font-bold text-gray-900"><%= @reading_session.book.progress_percentage %>%</dd>
          </div>
        </dl>

        <!-- Stop + Completion Form -->
        <div class="mt-8">
          <div class="flex justify-center" data-active-session-target="stopButton">
            <button type="button"
                    data-action="active-session#stop"
                    class="inline-flex items-center rounded-md bg-red-600 px-6 py-3 text-lg font-semibold text-white shadow-sm hover:bg-red-500 transition-colors">
              <svg class="-ml-0.5 mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <rect x="6" y="6" width="12" height="12" rx="1"/>
              </svg>
              Stop Reading
            </button>
          </div>

          <div data-active-session-target="completionForm" class="hidden">
            <%= form_with url: complete_reading_session_path(@reading_session), method: :post, class: "space-y-4" do |form| %>
              <div class="rounded-md bg-green-50 p-4">
                <p class="text-sm font-medium text-green-800">
                  Great session! What page did you finish on?
                </p>
              </div>
              <div>
                <label for="end_page" class="block text-sm font-medium text-gray-700">End Page</label>
                <div class="mt-1 flex items-center gap-3">
                  <%= number_field_tag :end_page,
                      @reading_session.book.actual_current_page,
                      min: @reading_session.book.first_page,
                      max: @reading_session.book.last_page,
                      class: "block w-32 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-lg",
                      data: { active_session_target: "endPageField" } %>
                  <span class="text-sm text-gray-500">
                    (pages <%= @reading_session.book.first_page %> - <%= @reading_session.book.last_page %>)
                  </span>
                </div>
              </div>
              <div class="flex justify-end gap-3 pt-2">
                <button type="button" data-action="active-session#cancelStop" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">
                  Cancel
                </button>
                <%= form.submit "Save Session", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Completed Session -->
    <div class="mt-8 rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">
            <svg class="-ml-0.5 mr-1.5 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Completed
          </span>
          <% if @reading_session.untracked? %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-600">Untracked</span>
          <% end %>
          <span class="text-sm text-gray-500"><%= @reading_session.started_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>

        <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
          <div class="rounded-lg bg-indigo-50 p-4 text-center">
            <dt class="text-sm text-indigo-600">Duration</dt>
            <dd class="mt-1 text-2xl font-bold text-indigo-900"><%= @reading_session.formatted_duration %></dd>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <dt class="text-sm text-green-600">Pages Read</dt>
            <dd class="mt-1 text-2xl font-bold text-green-900"><%= @reading_session.pages_read || 0 %></dd>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <dt class="text-sm text-amber-600">Reading Speed</dt>
            <dd class="mt-1 text-2xl font-bold text-amber-900">
              <%= @reading_session.words_per_minute ? "#{@reading_session.words_per_minute.round} WPM" : "-" %>
            </dd>
          </div>
          <div class="rounded-lg bg-gray-50 p-4 text-center">
            <dt class="text-sm text-gray-600">Page Range</dt>
            <dd class="mt-1 text-2xl font-bold text-gray-900">
              <%= @reading_session.actual_start_page %> &rarr; <%= @reading_session.actual_end_page || "-" %>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-6 flex justify-center gap-4">
      <%= button_to start_book_reading_sessions_path(@reading_session.book), method: :post, class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
        <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Start Another Session
      <% end %>
    </div>
  <% end %>
</div>
