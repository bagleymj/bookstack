<div class="space-y-6">
  <div class="md:flex md:items-center md:justify-between">
    <div class="min-w-0 flex-1">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
        Reading List
      </h2>
    </div>
  </div>

  <!-- Unowned books warning -->
  <% if @unowned_next_week.any? %>
    <div class="rounded-lg bg-amber-50 border border-amber-200 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3 flex-1">
          <h3 class="text-sm font-medium text-amber-800">Unowned books starting next week</h3>
          <div class="mt-2 text-sm text-amber-700">
            <ul class="list-disc pl-5 space-y-1">
              <% @unowned_next_week.each do |goal| %>
                <li class="flex items-center justify-between">
                  <span><strong><%= goal.book.title %></strong> starts <%= goal.started_on.strftime("%b %d") %></span>
                  <%= button_to "Mark as owned", book_path(goal.book, book: { owned: true }), method: :patch, class: "ml-3 inline-flex items-center rounded px-2 py-1 text-xs font-medium text-amber-800 bg-amber-200 hover:bg-amber-300" %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Pipeline Chart (read-only) -->
  <div class="rounded-lg bg-white shadow">
    <div class="px-4 py-5 sm:p-6">
      <div data-controller="pipeline-chart"
           data-pipeline-chart-url-value="<%= api_v1_pipeline_index_path %>"
           class="overflow-x-auto relative"
           style="touch-action: none;">
        <div class="min-h-[200px] flex items-center justify-center text-gray-500">
          Loading pipeline...
        </div>
      </div>
      <!-- Chart Legend -->
      <details class="mt-4 border-t border-gray-100 pt-3">
        <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-600 select-none">
          How to read this chart
        </summary>
        <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-xs text-gray-500">
          <div class="flex items-center gap-2">
            <span class="inline-block w-4 h-3 rounded-sm bg-indigo-500"></span>
            Each color is a book, stacked by day
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-400" viewBox="0 0 16 16"><line x1="2" y1="8" x2="14" y2="8" stroke="currentColor" stroke-width="1.5"/></svg>
            X-axis = dates, Y-axis = minutes/day
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block w-4 h-3 rounded-sm bg-indigo-500 opacity-100"></span>
            Solid past bricks = actual reading time
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block w-4 h-3 rounded-sm bg-indigo-300"></span>
            Lighter future bricks = planned time
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block w-4 h-0.5 bg-red-500"></span>
            Red dashed line = today
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block w-4 h-3 rounded-sm bg-gray-100"></span>
            Gray shading = weekends
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-3" viewBox="0 0 16 12"><rect x="1" y="1" width="14" height="10" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="3 2" rx="1"/></svg>
            Amber dashed border = unowned book
          </div>
          <div class="flex items-start gap-2">
            <span class="inline-block mt-0.5 w-4 h-3 rounded-sm bg-indigo-200 opacity-50"></span>
            Dimmed bricks = queued (not yet started)
          </div>
        </div>
        <p class="mt-2 text-xs text-gray-400">Hover a brick for details. Click to view the reading goal.</p>
      </details>
    </div>
  </div>

  <!-- Currently Reading -->
  <% if @currently_reading.any? %>
    <div>
      <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Currently Reading</h3>
      <div class="space-y-3">
        <% @currently_reading.each do |goal| %>
          <%= link_to goal, class: "block rounded-lg bg-white shadow p-4 hover:shadow-md transition-shadow" do %>
            <div class="flex items-center gap-4">
              <% if goal.book.cover_image_url.present? %>
                <img src="<%= goal.book.cover_image_url %>" alt="" class="w-12 h-16 object-cover rounded shadow-sm flex-shrink-0">
              <% else %>
                <div class="w-12 h-16 bg-gray-200 rounded flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between">
                  <span class="font-medium text-gray-900 truncate"><%= goal.book.title %></span>
                  <div class="flex items-center gap-2 ml-2 flex-shrink-0">
                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                      <% if goal.not_started? %>
                        bg-gray-100 text-gray-800">Not Started
                      <% elsif goal.tracking_status == :caught_up %>
                        bg-green-100 text-green-800">Caught Up
                      <% elsif goal.tracking_status == :reading_due %>
                        bg-blue-100 text-blue-800">Reading Due
                      <% else %>
                        bg-yellow-100 text-yellow-800">Behind
                      <% end %>
                    </span>
                    <span class="text-xs text-gray-500">ends <%= goal.target_completion_date&.strftime("%b %d") %></span>
                  </div>
                </div>
                <% if goal.book.author.present? %>
                  <p class="text-sm text-gray-500"><%= goal.book.author %></p>
                <% end %>
                <div class="mt-2 flex items-center justify-between">
                  <div class="flex-1 flex items-center gap-2">
                    <div class="flex-1 bg-gray-200 rounded-full h-2">
                      <div class="bg-indigo-500 h-2 rounded-full" style="width: <%= goal.book.progress_percentage %>%"></div>
                    </div>
                    <span class="text-xs text-gray-500"><%= goal.book.progress_percentage %>%</span>
                  </div>
                  <span class="text-xs text-gray-500 ml-4">
                    <% if goal.not_started? %>
                      <%= goal.goal_reading_days %> day duration
                    <% else %>
                      <%= goal.days_remaining %> days left
                    <% end %>
                  </span>
                </div>
                <% if goal.today_quota %>
                  <div class="mt-2 p-2 rounded-md text-xs <%= goal.today_quota.effectively_complete? ? 'bg-green-50' : 'bg-gray-50' %>">
                    <div class="flex items-center justify-between">
                      <span class="text-gray-600">Today's quota</span>
                      <% if goal.today_quota.effectively_complete? %>
                        <span class="font-medium text-green-600">Complete!</span>
                      <% else %>
                        <span class="font-medium text-gray-900">
                          <%= goal.today_quota.actual_pages %> / <%= goal.today_quota.target_pages %> pages &rarr; p. <%= goal.today_quota.target_page_number %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Up Next (draggable) -->
  <div data-controller="reading-list" data-reading-list-url-value="<%= reorder_api_v1_reading_list_index_path %>">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">
      Up Next
      <% if @up_next.any? %>
        <span class="text-gray-400 font-normal">&mdash; drag to reorder</span>
      <% end %>
    </h3>

    <% if @up_next.any? %>
      <div data-reading-list-target="list" class="space-y-3">
        <% @up_next.each_with_index do |goal, index| %>
          <div data-reading-list-target="item"
               data-goal-id="<%= goal.id %>"
               draggable="true"
               class="rounded-lg bg-white shadow p-4 cursor-grab active:cursor-grabbing transition-all">
            <div class="flex items-center gap-4">
              <!-- Drag handle -->
              <div class="text-gray-300 flex-shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M7 2a2 2 0 10.001 4.001A2 2 0 007 2zm0 6a2 2 0 10.001 4.001A2 2 0 007 8zm0 6a2 2 0 10.001 4.001A2 2 0 007 14zm6-8a2 2 0 10-.001-4.001A2 2 0 0013 6zm0 2a2 2 0 10.001 4.001A2 2 0 0013 8zm0 6a2 2 0 10.001 4.001A2 2 0 0013 14z"/>
                </svg>
              </div>

              <% if goal.book.cover_image_url.present? %>
                <img src="<%= goal.book.cover_image_url %>" alt="" class="w-12 h-16 object-cover rounded shadow-sm flex-shrink-0">
              <% else %>
                <div class="w-12 h-16 bg-gray-200 rounded flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                </div>
              <% end %>

              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between">
                  <%= link_to goal.book.title, book_path(goal.book), class: "font-medium text-gray-900 hover:text-indigo-600 truncate" %>
                  <button type="button"
                          data-action="click->reading-list#removeItem"
                          data-goal-id="<%= goal.id %>"
                          class="ml-2 p-1 text-gray-400 hover:text-red-500 rounded hover:bg-red-50 flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </button>
                </div>
                <% if goal.book.author.present? %>
                  <p class="text-sm text-gray-500"><%= goal.book.author %></p>
                <% end %>
                <div class="mt-1 flex items-center gap-3 text-xs text-gray-500">
                  <span><%= goal.book.total_pages %> pages</span>
                  <span>~<%= goal.book.formatted_estimated_time %></span>
                  <% if goal.started_on.present? && goal.target_completion_date.present? %>
                    <span data-reading-list-target="dates" data-goal-id="<%= goal.id %>" class="text-indigo-600">
                      <%= goal.started_on.strftime("%b %d") %> - <%= goal.target_completion_date.strftime("%b %d") %>
                    </span>
                  <% elsif goal.queued? %>
                    <span class="text-amber-600">Queued</span>
                  <% end %>
                </div>
                <% if goal.book.reading? %>
                  <div class="mt-1.5">
                    <div class="flex items-center gap-2">
                      <div class="flex-1 bg-gray-200 rounded-full h-1.5">
                        <div class="bg-indigo-500 h-1.5 rounded-full" style="width: <%= goal.book.progress_percentage %>%"></div>
                      </div>
                      <span class="text-xs text-gray-400"><%= goal.book.progress_percentage %>%</span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-lg border-2 border-dashed border-gray-300 p-8 text-center">
        <svg class="mx-auto w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <p class="mt-2 text-sm text-gray-500">No books in your reading list yet.</p>
        <p class="text-xs text-gray-400 mt-1">Add books from your library below to get started.</p>
      </div>
    <% end %>
  </div>

  <!-- Library — add to reading list -->
  <% if @available_books.any? %>
    <div>
      <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">
        Library
        <span class="text-gray-400 font-normal">&mdash; click + to schedule</span>
      </h3>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <% @available_books.each do |book| %>
          <div class="rounded-lg bg-white shadow p-4 flex items-center gap-3"
               data-controller="quick-add" data-quick-add-book-id-value="<%= book.id %>">
            <% if book.cover_image_url.present? %>
              <img src="<%= book.cover_image_url %>" alt="" class="w-10 h-14 object-cover rounded shadow-sm flex-shrink-0">
            <% else %>
              <div class="w-10 h-14 bg-gray-200 rounded flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <div class="font-medium text-gray-900 text-sm truncate"><%= book.title %></div>
              <% if book.author.present? %>
                <div class="text-xs text-gray-500 truncate"><%= book.author %></div>
              <% end %>
              <div class="text-xs text-gray-400 mt-0.5"><%= book.total_pages %> pages</div>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <% delta = @book_impacts[book.id] || 0 %>
              <% if delta != 0 %>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                  <%= delta > 0 ? 'bg-amber-100 text-amber-700' : 'bg-green-100 text-green-700' %>">
                  <%= delta > 0 ? "+#{delta}" : delta %>m
                </span>
              <% end %>
              <button type="button"
                      data-action="click->quick-add#add"
                      data-quick-add-target="button"
                      class="p-1.5 rounded-full text-indigo-600 hover:bg-indigo-50 hover:text-indigo-700 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Completed Goals -->
  <% if @completed_goals.any? %>
    <div class="space-y-4">
      <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Completed</h3>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% @completed_goals.each do |goal| %>
          <div class="rounded-lg bg-white p-4 shadow">
            <h4 class="font-medium text-gray-900"><%= goal.book.title %></h4>
            <p class="text-sm text-gray-500">Completed <%= time_ago_in_words(goal.updated_at) %> ago</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @currently_reading.empty? && @up_next.empty? && @completed_goals.empty? && @available_books.empty? %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No books on your reading list</h3>
      <p class="mt-1 text-sm text-gray-500">Add books to see them scheduled on your pipeline.</p>
    </div>
  <% end %>
</div>
