<div class="space-y-6">
  <h2 class="text-2xl font-bold text-gray-900">Profile Settings</h2>

  <%= form_with model: current_user, url: profile_path, method: :patch, class: "space-y-8" do |form| %>
    <% if current_user.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-800">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Account -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Account</h3>
        <div class="mt-4 max-w-md">
          <label class="block text-sm font-medium text-gray-700">Name</label>
          <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
    </div>

    <!-- Reading Defaults -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Reading Defaults</h3>
        <p class="mt-1 text-sm text-gray-500">Used when creating new books and estimating reading time.</p>
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 max-w-md">
          <div>
            <label class="block text-sm font-medium text-gray-700">Words per page</label>
            <%= form.number_field :default_words_per_page, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Reading speed (WPM)</label>
            <%= form.number_field :default_reading_speed_wpm, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Reading Pace -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Reading Pace</h3>
        <p class="mt-1 text-sm text-gray-500">Set the reading pace you want to maintain. Tracked on your dashboard.</p>
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 max-w-md">
          <div>
            <label class="block text-sm font-medium text-gray-700">Pace type</label>
            <%= form.select :reading_pace_type,
                options_for_select([
                  ["None", ""],
                  ["Books per year", "books_per_year"],
                  ["Books per month", "books_per_month"],
                  ["Books per week", "books_per_week"],
                  ["Minutes per day", "minutes_per_day"]
                ], current_user.reading_pace_type),
                {},
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Target</label>
            <%= form.number_field :reading_pace_value, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "e.g. 52" %>
          </div>
        </div>
        <% if current_user.reading_pace_set_on.present? %>
          <p class="mt-2 text-xs text-gray-400">Tracking since <%= current_user.reading_pace_set_on.strftime('%b %-d, %Y') %>. Changing the pace resets the start date.</p>
        <% end %>
        <% if current_user.reading_pace_type.present? %>
          <% derived = current_user.derive_daily_minutes_from_pace %>
          <div class="mt-3 rounded-md bg-indigo-50 p-3">
            <p class="text-sm text-indigo-800">
              This pace requires approximately <strong><%= derived %> min/day</strong> of reading.
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Scheduling -->
    <div class="rounded-lg bg-white shadow" data-controller="profile">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Scheduling</h3>
        <p class="mt-1 text-sm text-gray-500">Controls how the reading list auto-schedules your books.</p>
        <div class="mt-4 space-y-4 max-w-md">
          <div>
            <label class="block text-sm font-medium text-gray-700">Max concurrent books</label>
            <p class="text-xs text-gray-500">How many books you want to read at the same time.</p>
            <%= form.number_field :max_concurrent_books, min: 1, max: 10, class: "mt-1 block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Daily reading (min)</label>
            <%= form.number_field :weekday_reading_minutes, min: 0, max: 480, class: "mt-1 block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Weekend mode</label>
            <%= form.select :weekend_mode,
                options_for_select([
                  ["Same as weekdays", "same"],
                  ["Skip weekends", "skip"],
                  ["Capped weekend time", "capped"]
                ], current_user.weekend_mode),
                {},
                class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                data: { action: "change->profile#toggleWeekendCap" } %>
          </div>
          <div id="weekend-cap-field" class="<%= 'hidden' unless current_user.capped? %>">
            <label class="block text-sm font-medium text-gray-700">Weekend cap (min/day)</label>
            <%= form.number_field :weekend_reading_minutes, min: 1, max: 480, class: "mt-1 block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <% if current_user.reading_pace_type.present? %>
            <p class="mt-2 text-xs text-gray-500">
              Set by your reading pace. Changing your pace will update these values.
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <div>
      <%= form.submit "Save", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
    </div>
  <% end %>
</div>
