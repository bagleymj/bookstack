<div class="space-y-6">
  <h2 class="text-2xl font-bold text-gray-900">Profile Settings</h2>

  <%= form_with model: current_user, url: profile_path, method: :patch, class: "space-y-8" do |form| %>
    <% if current_user.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <ul class="list-disc pl-5 text-sm text-red-800">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Account -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Account</h3>
        <div class="mt-4 max-w-md">
          <label class="block text-sm font-medium text-gray-700">Name</label>
          <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
        </div>
      </div>
    </div>

    <!-- Reading Defaults -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Reading Defaults</h3>
        <p class="mt-1 text-sm text-gray-500">Used when creating new books and estimating reading time.</p>
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 max-w-md">
          <div>
            <label class="block text-sm font-medium text-gray-700">Words per page</label>
            <%= form.number_field :default_words_per_page, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700">Reading speed (WPM)</label>
            <%= form.number_field :default_reading_speed_wpm, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Scheduling -->
    <div class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium text-gray-900">Scheduling</h3>
        <p class="mt-1 text-sm text-gray-500">Controls how the reading list auto-schedules your books.</p>
        <div class="mt-4 space-y-4 max-w-md">
          <div>
            <label class="block text-sm font-medium text-gray-700">Max concurrent books</label>
            <p class="text-xs text-gray-500">How many books you want to read at the same time.</p>
            <%= form.number_field :max_concurrent_books, min: 1, max: 10, class: "mt-1 block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700">Weekday reading (min)</label>
              <%= form.number_field :weekday_reading_minutes, min: 0, max: 480, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700">Weekend reading (min)</label>
              <%= form.number_field :weekend_reading_minutes, min: 0, max: 480, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div>
      <%= form.submit "Save", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
    </div>
  <% end %>
</div>
