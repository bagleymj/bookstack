#!/usr/bin/env bash
# Database restore script for BookStack

set -e

BACKUP_DIR=".postgres/backups"

if [ -z "$1" ]; then
  echo "Usage: bin/db_restore <backup_file>"
  echo ""
  echo "Available backups:"
  ls -lt "$BACKUP_DIR"/*.sql 2>/dev/null | head -10 || echo "No backups found"
  exit 1
fi

BACKUP_FILE="$1"

if [ ! -f "$BACKUP_FILE" ]; then
  # Try with backup dir prefix
  BACKUP_FILE="$BACKUP_DIR/$1"
fi

if [ ! -f "$BACKUP_FILE" ]; then
  echo "Error: Backup file not found: $1"
  exit 1
fi

echo "WARNING: This will replace all data in bookstack_development!"
read -p "Are you sure? (yes/no): " confirm

if [ "$confirm" != "yes" ]; then
  echo "Aborted."
  exit 1
fi

echo "Restoring from $BACKUP_FILE..."
psql -h localhost bookstack_development < "$BACKUP_FILE"
echo "Restore complete."
