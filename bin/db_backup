#!/usr/bin/env bash
# Database backup script for BookStack

set -e

BACKUP_DIR=".postgres/backups"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="$BACKUP_DIR/bookstack_$TIMESTAMP.sql"

mkdir -p "$BACKUP_DIR"

echo "Backing up database to $BACKUP_FILE..."
pg_dump -h localhost bookstack_development > "$BACKUP_FILE"

echo "Backup created: $BACKUP_FILE"
echo "Size: $(du -h "$BACKUP_FILE" | cut -f1)"

# Keep only last 10 backups
cd "$BACKUP_DIR"
ls -t *.sql 2>/dev/null | tail -n +11 | xargs -r rm --
echo "Cleanup complete. Keeping last 10 backups."
